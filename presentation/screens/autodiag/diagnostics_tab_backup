  Widget _buildSingleChart(BuildContext context, String pid, List<PidMeta> meta) {
    final m = _metaFor(pid, meta);
    final spots = _spotsFor(pid);
    
    if (spots.isEmpty) {
      return Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            Icon(
              Icons.show_chart,
              size: 64,
              color: Theme.of(context).colorScheme.primary,
            ),
            const SizedBox(height: 16),
            Text(
              'Нет данных',
              style: Theme.of(context).textTheme.titleLarge,
            ),
            const SizedBox(height: 8),
            Text(
              'Начните опрос для построения графика',
              style: Theme.of(context).textTheme.bodyMedium?.copyWith(
                color: Theme.of(context).colorScheme.onSurfaceVariant,
              ),
            ),
          ],
        ),
      );
    }

    double minY = double.infinity;
    double maxY = -double.infinity;
    for (final s in spots) {
      if (s.y < minY) minY = s.y;
      if (s.y > maxY) maxY = s.y;
    }
    
    if (minY == maxY) {
      minY -= 1;
      maxY += 1;
    }
    
    final pad = (maxY - minY) * 0.12 + 1;
    minY = (minY - pad).clamp(0, double.infinity);
    maxY = maxY + pad;

    return Column(
      children: [
        // Заголовок графика
        Card(
          child: Padding(
            padding: const EdgeInsets.all(16.0),
            child: Row(
              children: [
                Icon(
                  Icons.speed,
                  color: Theme.of(context).colorScheme.primary,
                ),
                const SizedBox(width: 12),
                Expanded(
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      Text(
                        m?.name ?? 'PID $pid',
                        style: Theme.of(context).textTheme.titleMedium?.copyWith(
                          fontWeight: FontWeight.bold,
                        ),
                      ),
                      Text(
                        'PID $pid',
                        style: Theme.of(context).textTheme.bodySmall?.copyWith(
                          color: Theme.of(context).colorScheme.onSurfaceVariant,
                        ),
                      ),
                    ],
                  ),
                ),
                if (diag.livePidValues[pid.toUpperCase()] != null)
                  Column(
                    crossAxisAlignment: CrossAxisAlignment.end,
                    children: [
                      Text(
                        '${diag.livePidValues[pid.toUpperCase()]?.toStringAsFixed(1)}',
                        style: Theme.of(context).textTheme.headlineSmall?.copyWith(
                          fontWeight: FontWeight.bold,
                          color: Theme.of(context).colorScheme.primary,
                        ),
                      ),
                      Text(
                        m?.unit ?? '',
                        style: Theme.of(context).textTheme.bodySmall,
                      ),
                    ],
                  ),
              ],
            ),
          ),
        ),
        
        const SizedBox(height: 16),
        
        // График
        Expanded(
          child: Card(
            child: Padding(
              padding: const EdgeInsets.all(16.0),
              child: LineChart(
                LineChartData(
                  minY: minY,
                  maxY: maxY,
                  clipData: const FlClipData.all(),
                  gridData: FlGridData(
                    show: true,
                    drawVerticalLine: false,
                    horizontalInterval: (maxY - minY) > 10 ? (maxY - minY) / 5 : null,
                  ),
                  titlesData: FlTitlesData(
                    bottomTitles: AxisTitles(
                      sideTitles: SideTitles(
                        showTitles: true,
                        reservedSize: 24,
                        interval: 1,
                        getTitlesWidget: (v, m) {
                          if (v != v.roundToDouble()) return const SizedBox.shrink();
                          return Padding(
                            padding: const EdgeInsets.only(top: 8),
                            child: Text(
                              '${v.toInt()}',
                              style: Theme.of(context).textTheme.labelSmall,
                            ),
                          );
                        },
                      ),
                    ),
                    leftTitles: AxisTitles(
                      sideTitles: SideTitles(
                        showTitles: true,
                        reservedSize: 44,
                        getTitlesWidget: (v, m) => Text(
                          v.toStringAsFixed(v >= 100 ? 0 : 1),
                          style: Theme.of(context).textTheme.labelSmall,
                        ),
                      ),
                    ),
                    topTitles: const AxisTitles(sideTitles: SideTitles(showTitles: false)),
                    rightTitles: const AxisTitles(sideTitles: SideTitles(showTitles: false)),
                  ),
                  borderData: FlBorderData(
                    show: true,
                    border: Border.all(
                      color: Theme.of(context).dividerColor.withValues(alpha: 0.4),
                    ),
                  ),
                  lineTouchData: LineTouchData(
                    enabled: true,
                    touchTooltipData: LineTouchTooltipData(
                      getTooltipItems: (spots) {
                        return spots.map((s) {
                          final name = m?.name ?? pid;
                          final unit = m?.unit ?? '';
                          return LineTooltipItem(
                            '$name\n${s.y.toStringAsFixed(1)} $unit',
                            TextStyle(
                              color: Theme.of(context).colorScheme.onInverseSurface,
                              fontSize: 12,
                            ),
                          );
                        }).toList();
                      },
                    ),
                  ),
                  lineBarsData: [
                    LineChartBarData(
                      spots: spots,
                      color: Theme.of(context).colorScheme.primary,
                      barWidth: 3,
                      isCurved: true,
                      curveSmoothness: 0.25,
                      preventCurveOverShooting: true,
                      dotData: FlDotData(
                        show: spots.length <= 20,
                      ),
                    ),
                  ],
                ),
                duration: Duration.zero,
              ),
            ),
          ),
        ),
      ],
    );
  }

  PidMeta? _metaFor(String pid, List<PidMeta> all) {
    final u = pid.toUpperCase().padLeft(2, '0');
    for (final m in all) {
      if (m.pidCode.toUpperCase() == u) return m;
    }
    return null;
  }

  List<FlSpot> _spotsFor(String pid) {
    final key = pid.toUpperCase();
    final h = diag.chartHistory[key] ?? [];
    return [
      for (var i = 0; i < h.length; i++) FlSpot(i.toDouble(), h[i]),
    ];
  }

  Future<void> _pickPids(BuildContext context, List<PidMeta> meta) async {
    final chosen = Set<String>.from(diag.selectedPids);
    await showModalBottomSheet<void>(
      context: context,
      isScrollControlled: true,
      builder: (ctx) {
        return DraggableScrollableSheet(
          expand: false,
          initialChildSize: 0.7,
          maxChildSize: 0.95,
          builder: (_, sc) => StatefulBuilder(
            builder: (ctx, setSt) {
              return Column(
                children: [
                  const ListTile(title: Text('Отображаемые PID (макс. 6)')),
                  Expanded(
                    child: ListView.builder(
                      controller: sc,
                      itemCount: meta.length,
                      itemBuilder: (_, i) {
                        final p = meta[i];
                        final sel = chosen.contains(p.pidCode.toUpperCase());
                        return CheckboxListTile(
                          value: sel,
                          title: Text('${p.name} (${p.pidCode})'),
                          subtitle: chosen.length >= 6 && !sel 
                              ? const Text('Достигнут лимит', style: TextStyle(color: Colors.red))
                              : null,
                          onChanged: (v) {
                            setSt(() {
                              final c = p.pidCode.toUpperCase();
                              if (v == true) {
                                if (chosen.length < 6) {
                                  chosen.add(c);
                                }
                              } else {
                                chosen.remove(c);
                              }
                            });
                          },
                        );
                      },
                    ),
                  ),
                  FilledButton(
                    onPressed: () {
                      diag.setSelectedPids(chosen.isEmpty ? {'0C'} : chosen);
                      Navigator.pop(ctx);
                    },
                    child: const Text('Готово'),
                  ),
                  const SizedBox(height: 8),
                ],
              );
            },
          ),
        );
      },
    );
  }
}
