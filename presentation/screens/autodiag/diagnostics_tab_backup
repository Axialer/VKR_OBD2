                              ? Theme.of(context).colorScheme.onPrimaryContainer
                              : Theme.of(context).colorScheme.onErrorContainer)
                          : Theme.of(context).colorScheme.onSurfaceVariant,
                    ),
                  ),
                  title: Text(
                    meta?.name ?? 'PID $pid',
                    style: const TextStyle(fontWeight: FontWeight.w600),
                  ),
                  subtitle: Text(
                    meta?.unit ?? '',
                    style: TextStyle(
                      color: Theme.of(context).colorScheme.onSurfaceVariant,
                    ),
                  ),
                  trailing: Column(
                    mainAxisAlignment: MainAxisAlignment.center,
                    crossAxisAlignment: CrossAxisAlignment.end,
                    children: [
                      Text(
                        value != null ? '${value.toStringAsFixed(1)}' : '---',
                        style: TextStyle(
                          fontSize: 16,
                          fontWeight: FontWeight.bold,
                          color: value != null
                              ? (isNormal 
                                  ? Theme.of(context).colorScheme.primary
                                  : Theme.of(context).colorScheme.error)
                              : Theme.of(context).colorScheme.onSurfaceVariant,
                        ),
                      ),
                      if (meta?.normalMin != null && meta?.normalMax != null)
                        Text(
                          'Норма: ${meta!.normalMin}-${meta.normalMax}',
                          style: TextStyle(
                            fontSize: 12,
                            color: Theme.of(context).colorScheme.onSurfaceVariant,
                          ),
                        ),
                    ],
                  ),
                ),
              );
            },
          ),
        ),
      ],
    );
  }

  bool _isValueNormal(PidMeta? meta, double? value) {
    if (meta == null || value == null) return false;
    if (meta.normalMin == null || meta.normalMax == null) return true;
    return value >= meta.normalMin! && value <= meta.normalMax!;
  }

  IconData _getPidIcon(String pid) {
    switch (pid.toUpperCase()) {
      case '0C': return Icons.speed;
      case '0D': return Icons.tachometer;
      case '05': return Icons.thermostat;
      case '04': return Icons.local_fire_department;
      case '11': return Icons.air;
      case '42': return Icons.battery_full;
      default: return Icons.sensors;
    }
  }

  Future<void> _pickPids(BuildContext context) async {
    final all = await repo.allPidMeta();
    if (!context.mounted) return;
    
    final supported = all.where((m) => diag.supportedPids.contains(m.pidCode.toUpperCase())).toList();
    
    final selected = await showDialog<Set<String>>(
      context: context,
      builder: (context) => _PidPickerDialog(
        availablePids: supported,
        initialSelection: diag.selectedPids,
      ),
    );
    
    if (selected != null) {
      diag.setSelectedPids(selected);
    }
  }
}

